# Required: Telegram bot token (from @BotFather).
FLOWAI_TELEGRAM_BOT_TOKEN=1234:replace-me

# Required: comma-separated chat IDs authorized to control the IDE.
# Find your chat id with @userinfobot on Telegram.
FLOWAI_TELEGRAM_CHAT_ID=123456789

# Optional: restrict to specific topic ids inside a forum-enabled group.
# FLOWAI_TELEGRAM_ALLOWED_THREAD_IDS=42,43

# Required: which AI IDE backend to use. One of: claude | opencode | cursor.
FLOWAI_BRIDGE_IDE=claude

# Note: the project directory is always the directory `deno task` is launched
# from. There is no env var for it.
#
# Runtime-tunable IDE settings (model, effort, permission mode, timeout,
# retries, retry delay) are NOT configured via env — set them via Telegram
# commands. Values are persisted in `.tg-ide-bridge/session.json`.
#   /stop                  — abort the current IDE call
#   /settings              — show current effective settings
#   /model <value|clear>   — Claude Code: sonnet | opus | haiku | ...
#   /effort <value|clear>  — Claude only: low | medium | high | xhigh | max
#   /perm <value|clear>    — e.g. acceptEdits | plan | bypassPermissions
#   /timeout <seconds>     — per-invocation timeout (default 600)
#   /retries <count>       — runtime retry attempts (default 1)
#   /retry_delay <seconds> — base delay between retries (default 2)
